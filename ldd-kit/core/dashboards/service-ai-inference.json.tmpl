{
  "dashboard": {
    "id": null,
    "uid": "{{ DASHBOARD_UID_PREFIX }}-ai-inference",
    "title": "{{ SERVICE_NAME | capitalize }} — AI Inference",
    "tags": ["{{ SERVICE_NAME }}", "ai", "inference", "ml"],
    "timezone": "utc",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": {
            "text": "prometheus",
            "value": "prometheus"
          },
          "hide": 0
        },
        {
          "name": "model",
          "type": "query",
          "query": {
            "query": "label_values({{ METRIC_PREFIX }}_inference_duration_seconds_bucket, model)",
            "refId": "PrometheusVariableQueryEditor-VariableQuery"
          },
          "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
          "refresh": 1,
          "multi": true,
          "includeAll": true,
          "hide": 0
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Model Latency (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate({{ METRIC_PREFIX }}_inference_duration_seconds_bucket{model=~\"${model}\"}[5m])) by (model)",
            "legendFormat": "{% raw %}{{ model }}{% endraw %} — p95",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          },
          {
            "expr": "histogram_quantile(0.99, rate({{ METRIC_PREFIX }}_inference_duration_seconds_bucket{model=~\"${model}\"}[5m])) by (model)",
            "legendFormat": "{{ model }} — p99",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 0,
              "gradientMode": "none",
              "showPoints": "auto",
              "spanNulls": false
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 2, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 2,
        "title": "Inferences per Minute",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "rate({{ METRIC_PREFIX }}_inference_duration_seconds_count{model=~\"${model}\"}[1m]) * 60",
            "legendFormat": "{% raw %}{{ model }}{% endraw %}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "hue",
              "showPoints": "auto",
              "spanNulls": false
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "sum"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 3,
        "title": "Confidence Score Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "rate({{ METRIC_PREFIX }}_inference_confidence_score_bucket{model=~\"${model}\"}[5m])",
            "legendFormat": "{% raw %}{{ le }}{% endraw %}",
            "refId": "A",
            "format": "heatmap",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "scaleDistribution": {"type": "linear"},
              "hideFrom": {"legend": false, "tooltip": false, "viz": false}
            }
          },
          "overrides": []
        },
        "options": {
          "calculate": false,
          "yAxis": {
            "axisPlacement": "left",
            "axisLabel": "Confidence Score",
            "reverse": false,
            "decimals": 2
          },
          "rowsFrame": {"layout": "le"},
          "color": {
            "mode": "scheme",
            "fill": "dark-orange",
            "scale": "exponential",
            "exponent": 0.5
          },
          "cellGap": 1,
          "filter": "none",
          "tooltip": {
            "show": true,
            "yHistogram": true
          },
          "legend": {
            "show": true
          }
        }
      },
      {
        "id": 4,
        "title": "GPU Utilization",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "{{ METRIC_PREFIX }}_gpu_utilization_percent{model=~\"${model}\"}",
            "legendFormat": "{{ model }} — GPU %",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          },
          {
            "expr": "{{ METRIC_PREFIX }}_gpu_memory_utilization_percent{model=~\"${model}\"}",
            "legendFormat": "{{ model }} — Memory %",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 5,
              "gradientMode": "opacity",
              "showPoints": "auto",
              "spanNulls": false
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "red"}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 5,
        "title": "Inference Error Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "rate({{ METRIC_PREFIX }}_inference_errors_total{model=~\"${model}\"}[5m])",
            "legendFormat": "{{ model }} — errors/sec",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "opacity",
              "showPoints": "auto",
              "spanNulls": false
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.01, "color": "yellow"},
                {"value": 0.05, "color": "red"}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "sum"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 6,
        "title": "Cost per Inference",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "{{ METRIC_PREFIX }}_inference_cost_usd_per_call{model=~\"${model}\"}",
            "legendFormat": "{% raw %}{{ model }}{% endraw %}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "min": 0,
            "decimals": 4,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.01, "color": "yellow"},
                {"value": 0.05, "color": "red"}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["mean", "max", "lastNotNull"],
            "values": false,
            "fields": ""
          }
        }
      }
    ]
  },
  "overwrite": true
}
