{
  "dashboard": {
    "id": null,
    "uid": "{{ DASHBOARD_UID_PREFIX }}-overview",
    "title": "{{ SERVICE_NAME | capitalize }} — Overview",
    "tags": ["{{ SERVICE_NAME }}", "overview", "api"],
    "timezone": "utc",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": {
            "text": "prometheus",
            "value": "prometheus"
          },
          "hide": 0
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": {
            "type": "prometheus",
            "uid": {% raw %}"${datasource}"{% endraw %}
          },
          "expr": "count(kube_deployment_status_replicas_updated{deployment=~\"{{ SERVICE_NAME }}.*\"}) by (deployment)",
          "tagKeys": "deployment",
          "textFormat": "{% raw %}{{ deployment }}{% endraw %} deployed",
          "iconColor": "blue"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "rate({{ METRIC_PREFIX }}_requests_total[5m])",
            "legendFormat": "{% raw %}{{ method }}{% endraw %} {{ path }} — {{ status }}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "opacity",
              "showPoints": "auto",
              "spanNulls": false
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "rate({{ METRIC_PREFIX }}_requests_total{status=~\"5..\"}[5m])",
            "legendFormat": "{{ method }} {{ path }} — {{ status }}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 15,
              "gradientMode": "opacity",
              "showPoints": "never",
              "spanNulls": false
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 3,
        "title": "P95 Latency",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate({{ METRIC_PREFIX }}_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{ method }} {{ path }}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 0,
              "gradientMode": "none",
              "showPoints": "auto",
              "spanNulls": false
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 4,
        "title": "Active Requests",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "{{ METRIC_PREFIX }}_active_requests",
            "legendFormat": "Active Requests",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 100, "color": "red"}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "values": false,
            "fields": ""
          }
        }
      },
      {
        "id": 5,
        "title": "Business Events Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "rate({{ METRIC_PREFIX }}_events_total[1h])",
            "legendFormat": "{{ event_type }}/min",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "hue",
              "showPoints": "auto",
              "spanNulls": false
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "sum"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 6,
        "title": "API Calls by Dependency",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}},
        "targets": [
          {
            "expr": "sum by (service) (rate({{ METRIC_PREFIX }}_dependency_calls_total[5m]))",
            "legendFormat": "{% raw %}{{ service }}{% endraw %}",
            "refId": "A",
            "format": "table",
            "instant": true,
            "datasource": {"type": "prometheus", "uid": {% raw %}"${datasource}"{% endraw %}}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "blue"},
                {"value": 50, "color": "purple"},
                {"value": 100, "color": "orange"}
              ]
            },
            "custom": {
              "displayMode": "gradient",
              "orientation": "horizontal"
            }
          },
          "overrides": []
        },
        "options": {
          "orientation": "auto",
          "displayMode": "gradient",
          "showUnfilled": true,
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "values": false,
            "fields": ""
          }
        }
      }
    ]
  },
  "overwrite": true
}
